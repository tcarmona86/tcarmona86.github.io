# Vite expone al cliente solo las variables que empiezan con VITE_

# URL del backend real (se usa solo cuando VITE_USE_MOCK=false)
VITE_API_URL=http://localhost:8000/api

# true (default si no se define) -> usa datos de prueba (mockData.js), sin backend
# false -> usa el backend real definido en VITE_API_URL
VITE_USE_MOCK=true
